<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="invoice_view" model="ir.ui.view">
        <field name="name">Invoice View</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
<!--                <field name="test"/>-->
                <field name="stock_picking_id" string="Stock picking"/>
<!--                <field name="invoice_line_ids" string="new" force_save="1"/>-->
            </xpath>
        </field>
    </record>

    <record id="invoice_action_view" model="ir.actions.act_window">
        <field name="name">Invoice View</field>
        <field name="res_model">account.move</field>
        <field name="views">form,list</field>
    </record>
</odoo>
