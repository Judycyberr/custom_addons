<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <template id="report_hotel_management">
       <t t-call="web.html_container">
           <t t-call="web.external_layout">
               <div class="page">
                   <div class="oe_structure"/>
                   <h2>Hotel Management Report</h2>
                   <br/>
                   <table class="table">
                        <tr>
                            <th>Sl no</th>
                            <th>Customer</th>
                            <th>Check-in</th>
                            <th>Check-out</th>
                            <th>State</th>
                        </tr>
                        <t t-foreach="data.get('report')" t-as="o">
                            <tr class="text-center">
                                <td>
                                    <span t-esc="o['number']"/>
                                </td>
                                <td>
                                    <span t-esc="o['name']" />
                                </td>
                                <td>
                                    <span t-esc="o['check_in']" />
                                </td>
                                <td>
                                    <span t-esc="o['check_out']" />
                                </td>
                                <td>
                                    <span t-esc="o['state']" />
                                </td>
                            </tr>
                        </t>
                    </table>
               </div>
           </t>
       </t>
   </template>
</odoo>
