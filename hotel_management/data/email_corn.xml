<?xml version="1.0" encoding="UTF-8"?>
<odoo>
   <record id="cron_check_out_reminder" model="ir.cron">
           <field name="name">Check-out Reminder</field>
       <field name="model_id" ref="hotel_management.model_hotel_accommodation"/>
       <field name="state">code</field>
       <field name="code">model.send_mail()</field>
       <field name="interval_number">1</field>
       <field name="interval_type">days</field>
       <field name="active" eval="True"/>
       <field name="nextcall">2026-05-30 02:30:00</field>
   </record>
</odoo>
