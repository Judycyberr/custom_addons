<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
    <record id="lunch_product_rule_on_create" model="ir.actions.server">
        <field name="name">Create lunch product from food items</field>
        <field name="model_id" ref="hotel_management.model_hotel_food_items"/>
        <field name="state">code</field>
        <field name="code">
            action = record.create_food_product()
        </field>
    </record>

    <record id="automated_action_lunch_product_rule_on_create" model="base.automation">
        <field name="name">Base Automation: lunch rule on create</field>
        <field name="model_id" ref="hotel_management.model_hotel_food_items"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(4, ref('lunch_product_rule_on_create'))]"/>
    </record>
</data>
</odoo>