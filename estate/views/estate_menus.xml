    <menuitem id="estate_menu_root" name="Real Estate">
        <menuitem id="estate_first_level_menu" name="Properties">
            <menuitem id="estate_property_menu_action" name="Properties" action="estate_action"/>
        </menuitem>
        <menuitem id="property_type_first_level_menu" name="Settings">
            <menuitem id="property_type_menu_action" name="Property Type" action="estate_property_type"/>
            <menuitem id="property_tag_menu_action" name="Property Tag" action="estate_property_tag"/>
        </menuitem>
    </menuitem>

</odoo>