
<odoo>
    <record id="estate_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
    </record>



    <record id="estate_list_view" model="ir.ui.view">
        <field name="name">Properties</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="name"/>
                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="date_availability"/>
                <field name="tag_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="estate_form_view" model="ir.ui.view">
        <field name="name">Properties</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="form">
                <header>
                    <button name="sold" type="object" string="SOLD"/>
                    <button name="cancel" type="object" string="CANCEL"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <group>
                            <field name="property_type_id"/>
                        </group>
                        <group>
                            <field name="postcode"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                        </group>
                        <group>
                            <field name="date_availability"/>
                        </group>
                        <group>
                            <field name="selling_price"/>
                        </group>
                        <group>
                            <field name="best_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <group>
                                    <field name="description"/>
                                </group>
                                <group>
                                    <field name="bedrooms"/>
                                </group>
                                <group>
                                    <field name="living_area"/>
                                </group>
                                <group>
                                    <field name="facades"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="garage"/>
                                </group>
                                <group>
                                    <field name="garage_area"/>
                                </group>
                                <group>
                                    <field name="garden"/>
                                </group>
                                <group>
                                    <field name="garden_area"/>
                                </group>
                                <group>
                                    <field name="garden_orientation"/>
                                </group>
                                <group>
                                    <field name="status"/>
                                </group>
                                <group>
                                    <field name="total_area"/>
                                </group>
                                <group>
                                    <field name="active"/>
                                </group>
                            </group>

                        </page>
                        <page string="Offers">
                            <field name="offer_ids"/>
                        </page>
                        <page string="Other Info">
                            <group>
                                <group>
                                    <field name="user_id"/>
                                </group>
                                <group>
                                    <field name="partner_id"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_search_view" model="ir.ui.view">
        <field name="name">Properties</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Tests">
                <field name="name"/>
                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="expected_price"/>
                <field name="facades"/>
                <filter string="State(New or Offer Recieved)" name="state" domain="['|',    ('status','=','new'),('status','=','offer recieved')]" />
                <group>
                    <filter string="Group By(Post Code)" name="GroupBy" context="{'group_by':'postcode'}"/>
                </group>

            </search>
        </field>
    </record>

    <record id="estate_property_type" model="ir.actions.act_window">
        <field name="name">Property Type</field>
        <field name="res_model">property.type</field>
        <field name="views">form,list</field>
    </record>

    <record id="property_type_list_view" model="ir.ui.view">
        <field name="name">Property Type</field>
        <field name="model">property.type</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="estate_property_tag" model="ir.actions.act_window">
        <field name="name">Property Tag</field>
        <field name="res_model">property.tag</field>
        <field name="views">form,list</field>
    </record>

    <record id="property_tag_list_view" model="ir.ui.view">
        <field name="name">Property Tag</field>
        <field name="model">property.tag</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="estate_property_offer" model="ir.actions.act_window">
        <field name="name">Property Offer</field>
        <field name="res_model">property.offer</field>
        <field name="views">form,list</field>
    </record>

    <record id="property_offer_list_view" model="ir.ui.view">
        <field name="name">Property Offer</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="price"/>
                <field name="partner_id"/>
                <field name="validity"/>
                <field name="date_deadline"/>
                <field name="property_id"/>
                <button name="action_confirm" string="confirm" type="object" icon="fa-check"/>
                <button name="action_cancel" string="cancel" type="object" icon="fa-times"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="property_offer_form_view" model="ir.ui.view">
        <field name="name">Property Offers</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <form string="form">
                <sheet>
                    <group>
                        <field name="price"/>
                    </group>
                    <group>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="validity"/>
                    </group>
                    <group>
                        <field name="date_deadline"/>
                    </group>
                    <group>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>

    </record>

    <record id="estate_users" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">res.users</field>
        <field name="views">form,list</field>
    </record>

